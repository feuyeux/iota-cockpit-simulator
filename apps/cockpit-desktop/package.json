{
  "name": "cockpit-desktop",
  "version": "0.1.2",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 15342",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:tsc": "tsc -b --noEmit",
    "version:bundle": "node scripts/bump-bundle-version.mjs",
    "tauri:prepare-sidecar": "node scripts/prepare-sidecar.mjs",
    "tauri:dev": "npm run tauri:prepare-sidecar && tauri dev",
    "tauri:build": "npm run version:bundle && npm run tauri:prepare-sidecar && tauri build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.2",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^5.2.0",
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.2",
    "vite": "^7.3.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^3.2.7",
    "jsdom": "^25.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.7"
  }
}
