{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cockpit Simulation",
  "version": "0.1.2",
  "identifier": "com.feuyeux.cockpit-simulation",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 15342",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:15342",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Cockpit Simulation",
        "width": 1600,
        "height": 900,
        "minWidth": 1600,
        "minHeight": 900,
        "resizable": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "macOS": {
      "entitlements": "./Entitlements.plist",
      "signingIdentity": "-"
    },
    "resources": {
      "../../../scenarios": "scenarios",
      "../../../evaluations/private": "evaluations/private"
    },
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/cockpit-simulator",
      "binaries/cockpit-evaluator"
    ]
  }
}
